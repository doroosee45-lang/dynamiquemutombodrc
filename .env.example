# ============================================================
# DYNAMIQUE ISRAËL MUTOMBO — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs
# ============================================================

# ── Serveur ──────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── MongoDB Atlas ────────────────────────────────────────────
# Créez un cluster gratuit sur https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/dynamique_rdc?retryWrites=true&w=majority

# ── Redis (optionnel) ────────────────────────────────────────
# L'application fonctionne sans Redis (mode dégradé)
# REDIS_URL=redis://localhost:6379

# ── JWT Secrets ──────────────────────────────────────────────
JWT_SECRET=ChangezCeciEnProductionAvecUneLongueChaineAleatoire
JWT_REFRESH_SECRET=ChangezCeciAussiEnProductionDifferentDuPrecedent

# ── Email SMTP (Gmail) ───────────────────────────────────────
# Pour Gmail : activez "Authentification à 2 facteurs"
# puis créez un "Mot de passe d'application" dans les paramètres Google
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=votre.email@gmail.com
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx   # App Password (pas votre mdp)
EMAIL_FROM=Dynamique RDC <no-reply@dynamique-rdc.cd>

# ── Stockage médias AWS S3 (optionnel) ───────────────────────
# AWS_ACCESS_KEY_ID=your_aws_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret
# AWS_S3_BUCKET=dynamique-media
# AWS_REGION=eu-west-1
